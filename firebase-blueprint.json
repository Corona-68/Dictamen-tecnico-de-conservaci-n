{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A pavement design project containing all inputs and results.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "projectName": { "type": "string" },
        "section": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "generalData": { "type": "object" },
        "compositionData": { "type": "array", "items": { "type": "number" } },
        "axleInputs": { "type": "array" }
      },
      "required": ["userId", "projectName", "generalData"]
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of pavement design projects."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    }
  }
}
